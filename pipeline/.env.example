# Forge Publisher Pipeline Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (optional — Ollama is preferred)
OPEN_API_KEY=

# Ollama server URLs (add as many as needed)
OLLAMA_URL=http://localhost:11434
# OLLAMA_URL2=http://second-server.local:11434
# OLLAMA_URL3=http://third-server.local:11434

# Publisher branding (optional overrides)
# PUBLISHER_NAME=My Press
# ANNOTATOR_NAME=Bob the somewhat Humanist
# EDITION_VERSION=1.0.0
